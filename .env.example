# Clerk (auth del patrón/admin)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# MongoDB
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxx.mongodb.net/?appName=Cluster0
MONGODB_DB=centralia_personas

# Secret para sesiones de empleados (generá uno: openssl rand -hex 32)
EMPLOYEE_JWT_SECRET=change-me-please-32-bytes-min
