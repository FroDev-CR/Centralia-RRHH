        <div className="field" style={{ marginBottom: 14 }}><label>Tipo *</label><select value={f.tipo} onChange={(e) => up("tipo", e.target.value)}>{["Vacaciones", "Permiso", "Incapacidad"].map((o) => <option key={o}>{o}</option>)}</select></div>
